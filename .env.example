# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (embeddings) ──────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Database ─────────────────────────────────────────────────────────────────
# Local docker-compose (matches docker-compose.yml credentials):
DATABASE_URL=postgresql+asyncpg://gospel:gospel@localhost:5432/gospel_rag
# Neon (production) — use direct host (no -pooler), asyncpg handles sslmode:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-prod
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=voyage-3-lite
EMBEDDING_DIMENSIONS=512

# ── Generation models ─────────────────────────────────────────────────────────
GENERATION_MODEL=claude-sonnet-4-6
TITLING_MODEL=claude-haiku-4-5-20251001

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATES=20

# ── Observability (optional — leave blank to disable) ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=gospel-rag-api
