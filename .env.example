# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (embeddings only — text-embedding-3-small) ──────────────────────
OPENAI_API_KEY=sk-...

# ── Database ─────────────────────────────────────────────────────────────────
# Local docker-compose (matches docker-compose.yml credentials):
DATABASE_URL=postgresql+asyncpg://gospel:gospel@localhost:5432/gospel_rag
# Neon (production) — replace with your connection string:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/gospel_rag?sslmode=require

# ── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-prod
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512

# ── Generation models ─────────────────────────────────────────────────────────
GENERATION_MODEL=claude-sonnet-4-6
TITLING_MODEL=claude-haiku-4-5-20251001

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATES=20

# ── Observability (optional — leave blank to disable) ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=gospel-rag-api
